name: Feature Request Form
description: Suggest a new feature or enhancement.
title: "[Feature]: "
labels: ["enhancement", "triage"]
projects: ["u65042380107/AddVillageUtt", "u65042380107/drawNumber"]
body:
  - type: markdown
    attributes:
      value: |
        Thanks for taking the time to suggest a new feature! Please fill out the form below as clearly as possible.
  - type: input
    id: contact
    attributes:
      label: Contact Details
      description: How can we get in touch with you if we need more info?
      placeholder: ex. email@example.com
    validations:
      required: false
  - type: textarea
    id: problem-description
    attributes:
      label: Is your feature request related to a problem?
      description: A clear description of what the problem is.
      placeholder: ex. I'm always frustrated when...
    validations:
      required: true
  - type: textarea
    id: proposed-solution
    attributes:
      label: Describe the solution you'd like
      description: A clear and concise description of what you want to happen.
      placeholder: Tell us what you'd like to see!
    validations:
      required: true
  - type: textarea
    id: alternatives
    attributes:
      label: Describe alternatives you've considered
      description: A clear and concise description of any alternative solutions or features you've considered.
      placeholder: Any workarounds or alternatives you currently use?
    validations:
      required: false
  - type: dropdown
    id: priority
    attributes:
      label: Priority
      description: How important is this feature to you?
      options:
        - Low — nice to have
        - Medium — would improve my workflow
        - High — blocking or critical
      default: 0
    validations:
      required: true
  - type: dropdown
    id: area
    attributes:
      label: Feature area
      description: Which area of the project does this feature relate to?
      multiple: false
      options:
        - UI / UX
        - Performance
        - API / Integration
        - Documentation
        - Security
        - Other
    validations:
      required: true
  - type: textarea
    id: additional-context
    attributes:
      label: Additional context
      description: Add any other context, mockups, or references about the feature request here.
      render: markdown
    validations:
      required: false
  - type: upload
    id: screenshots
    attributes:
      label: Upload mockups or screenshots
      description: If applicable, add mockups or screenshots to help illustrate your idea.
    validations:
      required: false
  - type: checkboxes
    id: terms
    attributes:
      label: Code of Conduct
      description: By submitting this issue, you agree to follow our [Code of Conduct](https://example.com).
      options:
        - label: I agree to follow this project's Code of Conduct
          required: true
